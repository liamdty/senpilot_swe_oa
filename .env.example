PORT=3000
DOWNLOAD_LIMIT=10

MAILGUN_DOMAIN=mg.example.com
MAILGUN_API_KEY=key-your-mailgun-api-key
MAILGUN_FROM="UARB Documents Agent <agent@mg.example.com>"

OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_PARSE_MODEL=your-parse-model
OPENROUTER_REPLY_MODEL=your-reply-model

# Optional: set this to reject inbound webhooks with invalid Mailgun signatures.
MAILGUN_SIGNING_KEY=

